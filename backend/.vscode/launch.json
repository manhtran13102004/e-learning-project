        {
            "type": "java",
            "name": "Attach: author-service (5002)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5002
        },
        {
            "type": "java",
            "name": "Attach: user-service (5003)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5003
        },
        {
            "type": "java",
            "name": "Attach: service1 (5004)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5004
