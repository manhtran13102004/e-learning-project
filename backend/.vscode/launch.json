    "compounds": [
        {
            "name": "Attach: service1 + service2 (test pair)",
            "configurations": ["Attach: service1 (5004)", "Attach: service2 (5006)"]
        },
        {
            "name": "Attach: full system (5 core services)",
            "configurations": [
                "Attach: authn-service (5001)",
                "Attach: author-service (5002)",
                "Attach: user-service (5003)",
                "Attach: service1 (5004)",
