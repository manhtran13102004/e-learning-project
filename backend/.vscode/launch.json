            "mainClass": "vn.com.atomi.charge.user.UserServiceApplication",
            "projectName": "user-service",
            "envFile": "${workspaceFolder}/user-service/.env"
        },
        {
            "type": "java",
            "name": "AuthenticationServiceApplication",
            "request": "launch",
            "mainClass": "vn.com.atomi.charge.authn.AuthenticationServiceApplication",
            "projectName": "authn-service",
            "envFile": "${workspaceFolder}/authn-service/.env"
        },
        {
            "type": "java",
            "name": "AuthorizationServiceApplication",
            "request": "launch",
            "mainClass": "vn.com.atomi.charge.authorization.AuthorizationServiceApplication",
            "projectName": "author-service",
            "envFile": "${workspaceFolder}/author-service/.env"
        },
        {
            "type": "java",
            "name": "ApiGatewayApplication",
            "request": "launch",
            "mainClass": "vn.com.atomi.charge.gateway.ApiGatewayApplication",
